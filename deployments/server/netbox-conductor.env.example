# NetBox Conductor server configuration — copy to /etc/netbox-conductor/netbox-conductor.env
# File permissions: root:netbox-conductor 0640

# ── Required ──────────────────────────────────────────────────────────────────

# PostgreSQL connection string for the Conductor's own database
DATABASE_URL=postgres://netbox_conductor:changeme@localhost:5432/netbox_conductor?sslmode=disable

# Secret used to sign JWT tokens (min 32 random bytes, base64 or hex is fine)
JWT_SECRET=change-this-to-a-long-random-secret

# ── Network ───────────────────────────────────────────────────────────────────

# Address and port the server binds to.
# Default is 8443 — port 443 (standard HTTPS) requires root or CAP_NET_BIND_SERVICE,
# which the netbox-conductor service user does not have.
LISTEN_ADDR=:8443

# The conductor's reachable IP address. Must be a valid IPv4 or IPv6 address —
# not a hostname. Used as the listen address for Patroni Raft witnesses and,
# when SERVER_URL is not set, as the base URL included in agent ENV snippets.
# This field is required when any cluster uses active_standby (Patroni) mode.
SERVER_BIND_IP=192.168.1.10

# Public base URL included in agent ENV snippets (e.g. AGENT_SERVER_URL).
# Must be an IP address or fully-qualified domain name — must not be a bare
# hostname that only resolves on the local network.
# If omitted, the URL is derived from SERVER_BIND_IP and LISTEN_ADDR.
# Populate this only if agents should reach the conductor via a different
# address than SERVER_BIND_IP (e.g. a load balancer VIP or public DNS name).
# SERVER_URL=https://conductor.example.com

# ── Logging ───────────────────────────────────────────────────────────────────

# Root directory for log files
LOG_DIR=/var/log

# Instance name — becomes the top-level log subdirectory (<LOG_DIR>/<LOG_NAME>/)
# conductor.log and per-cluster/per-node agent logs are written here.
LOG_NAME=netbox-conductor

# Minimum log level: debug, info, warn, error (default: info)
# Use debug to see heartbeat details in conductor.log.
LOG_LEVEL=info

# ── Encryption ────────────────────────────────────────────────────────────────

# Path to the 32-byte AES-256-GCM master key file (root:netbox-conductor, 0400)
# NETBOX_CONDUCTOR_MASTER_KEY_FILE=/etc/netbox-conductor/master.key
# Or supply the key directly as an env var (file takes precedence):
# NETBOX_CONDUCTOR_MASTER_KEY=<32-byte hex or base64>

# ── TLS ───────────────────────────────────────────────────────────────────────

# Paths for the TLS cert and private key.
# On first startup the conductor auto-generates a self-signed ECDSA P-256 cert
# if these files do not exist. The cert is also its own CA — download it from
# GET /api/v1/downloads/ca.crt and set AGENT_TLS_CA_CERT on each agent node.
# To use your own cert (e.g. from Let's Encrypt), replace these files; the
# conductor will use them as-is and will not overwrite them.
TLS_CERT_FILE=/etc/netbox-conductor/tls.crt
TLS_KEY_FILE=/etc/netbox-conductor/tls.key

