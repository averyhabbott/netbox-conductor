# NetBox Agent configuration — copy to /etc/netbox-agent/netbox-agent.env
# File permissions: netbox-agent:netbox-agent 0600

# ── Required ──────────────────────────────────────────────────────────────────

# Assigned by the tool server during node registration
AGENT_NODE_ID=

# Bearer token for WebSocket authentication (set after registration)
AGENT_TOKEN=

# Conductor WebSocket URL — must use wss:// and include the port if not on 443
AGENT_SERVER_URL=wss://your-conductor.example.com:8443/api/v1/agent/connect

# ── TLS ───────────────────────────────────────────────────────────────────────

# When true (default), the agent downloads the conductor's CA cert on first start,
# saves it to /etc/netbox-agent/ca.crt, and sets AGENT_TLS_CA_CERT automatically.
# Set to false to disable auto-cert-learning (e.g. if you supply your own CA cert).
UPDATE_CERT=true

# Set to true ONLY for development — emits a warning at runtime
AGENT_TLS_SKIP_VERIFY=false

# Path to CA certificate for private/self-signed conductor cert.
# Populated automatically by cert-learning; you can also set it manually:
# AGENT_TLS_CA_CERT=/etc/netbox-agent/ca.crt

# ── Connection ────────────────────────────────────────────────────────────────

# Base reconnect interval in seconds (uses exponential backoff with jitter, max 120s)
AGENT_RECONNECT_INTERVAL_SECS=10

# Log level: debug, info, warn, error
AGENT_LOG_LEVEL=info

# ── NetBox paths ──────────────────────────────────────────────────────────────

# Absolute path to NetBox's configuration.py
NETBOX_CONFIG_PATH=/opt/netbox/netbox/netbox/configuration.py

# Absolute path to NetBox's media root directory
NETBOX_MEDIA_ROOT=/opt/netbox/netbox/media

# NetBox log forwarding.
# The agent automatically discovers log files by parsing the LOGGING section of
# NETBOX_CONFIG_PATH and tailing every file-based handler (RotatingFileHandler, etc.).
# Each log is stored and viewable via NodeDetail → Logs → NetBox, with a per-file dropdown.
#
# Set NETBOX_LOG_PATH only as a fallback when configuration.py has no LOGGING section:
# NETBOX_LOG_PATH=/opt/netbox/netbox/netbox.log

# ── Patroni ───────────────────────────────────────────────────────────────────

# Local Patroni REST API (leave as default unless you changed Patroni's restapi.listen)
PATRONI_REST_URL=http://127.0.0.1:8008

# ── Status server ─────────────────────────────────────────────────────────────

# Bind address for the local HTTP health endpoint (GET /status).
# Default: loopback only. Access is proxied through the node's nginx or Apache
# reverse proxy, which exposes /status on the public HTTPS port — so health
# checkers never need direct access to this port.
#
# Copy deployments/agent/nginx-netbox-conductor.conf (or apache-netbox-conductor.conf)
# into /etc/nginx/sites-available/ and symlink it into sites-enabled/ to enable
# this. No other changes to the agent are needed.
#
# Set to 0.0.0.0:8081 ONLY if your load balancer must probe the agent port
# directly (e.g. HAProxy on a separate host with no access to port 443).
# Leave empty to disable the status server entirely.
AGENT_STATUS_ADDR=127.0.0.1:8081
